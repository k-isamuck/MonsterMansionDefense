# Normalize line endings
* text=auto

# =========================
# UNITY: mark generated folders
# =========================
Library/** linguist-generated
Logs/** linguist-generated
Temp/** linguist-generated
UserSettings/** linguist-generated
Build/** linguist-generated
Builds/** linguist-generated

# Package cache (huge + auto generated)
Packages/** linguist-generated

# =========================
# UNITY ASSET FILES (misdetected as Wolfram / others)
# =========================
*.mat linguist-vendored
*.unity linguist-vendored
*.prefab linguist-vendored
*.asset linguist-vendored
*.anim linguist-vendored
*.controller linguist-vendored
*.lighting linguist-vendored
*.shadergraph linguist-vendored
*.shadervariants linguist-vendored
*.terrainlayer linguist-vendored

# Keep real code detectable
*.cs linguist-detectable=true
*.shader linguist-detectable=true